# ============================================================
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.
# ============================================================

# Base URLs (override defaults in karate-config.js)
BASE_URL=http://localhost:8080
JSON_PLACEHOLDER_URL=https://jsonplaceholder.typicode.com
RESTFUL_API_URL=https://api.restful-api.dev
HTTP_BINGO_URL=https://httpbingo.org
DUMMY_JSON_URL=https://dummyjson.com
GRAPHQL_URL=https://graphqlzero.almansi.me/api

# Credentials — replace with real values in .env
AUTH_TOKEN=your-bearer-token-here
API_KEY=your-api-key-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# DummyJSON credentials (token generated dynamically via karate.callSingle)
# Defaults in karate-config.js point to public test account — override for your own.
DUMMY_JSON_USERNAME=emilys
DUMMY_JSON_PASSWORD=emilyspass
